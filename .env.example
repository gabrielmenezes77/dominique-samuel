# =============================================================================
# Dominique & Samuel — Admin Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in the real values before running locally.
#
#   cp .env.example .env
#
# NEVER commit .env to version control. .env.example is safe to commit.
#
# All variables must be prefixed with VITE_ so Vite exposes them to the
# browser bundle at build time via import.meta.env.
# =============================================================================

# AWS region where the Cognito Admin User Pool was provisioned.
# Example: us-east-1
VITE_AWS_REGION=us-east-1

# App Client ID for the Cognito Admin User Pool.
# The App Client was created with generateSecret: false (no client secret).
# This value is public configuration — it is not a secret.
# Source: CognitoAdminStack outputs.
VITE_COGNITO_ADMIN_APP_CLIENT_ID=

# Base URL of the RSVP Admin API (CloudFront distribution root).
# Used by RsvpAdminClient to build /admin/rsvp* request paths.
# Do NOT include a trailing slash.
# Example: https://dominique-samuel.com
VITE_RSVP_ADMIN_API_BASE_URL=https://dominique-samuel.com

# Cognito authentication flow to use in InitiateAuth requests.
# Allowed values: USER_PASSWORD_AUTH | USER_SRP_AUTH
# USER_PASSWORD_AUTH sends credentials directly (simpler, requires HTTPS).
# USER_SRP_AUTH uses Secure Remote Password protocol (no plaintext password on wire).
# The Cognito Admin App Client supports both flows.
VITE_AUTH_FLOW=USER_PASSWORD_AUTH
